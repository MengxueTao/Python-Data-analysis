    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "x=np.linspace(-1,1,1000)\n",
    "y=x*x*2\n",
    "\n",
    "plt.figure(figsize=(20,8),dpi=80)\n",
    "\n",
    "plt.plot(x,y)\n",
    "\n",
    "plt.grid(linestyle=\"--\",alpha=0.5)\n",
    "\n",
    "plt.show()\n"
   ]
